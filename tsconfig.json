{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": [
      "bun-types",
      "node"
    ],
    "allowImportingTsExtensions": true
  },
  "include": [
    "src",
    "scripts"
  ]
}
