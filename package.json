{
  "name": "cli-prompt-launcher",
  "version": "0.1.0",
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/node": "^25.5.0",
    "bun-types": "^1.3.10",
    "typescript": "^5.9.3"
  },
  "bin": {
    "jj": "dist/jj"
  },
  "description": "Global jj launcher for Claude Code and Codex prompts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun run scripts/build.ts host",
    "build:release": "bun run scripts/build.ts release",
    "install:global": "bun run scripts/install-global.ts",
    "preview": "bun run build && bun run install:global"
  },
  "type": "module"
}
